{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TonyBase Capture",
  "version": "0.1.2",
  "identifier": "site.tonybase.capture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "TonyBase Capture",
        "width": 460,
        "height": 640,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "minimizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": null
      }
    }
  }
}
