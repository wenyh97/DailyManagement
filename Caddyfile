dailymanagement.tonybase.site {
    encode zstd gzip

    @backend {
        path /api /api/*
        path /events /events/*
        path /ideas /ideas/*
        path /event-types /event-types/*
        path /daily-scores /daily-scores/*
        path /daily-score-details /daily-score-details/*
        path /stats /stats/*
        path /health
    }

    handle @backend {
        reverse_proxy 127.0.0.1:5000
    }

    handle {
        root * /srv
        try_files {path} {path}/ /index.html
        file_server
    }
}